# =============================================================================
# REFERENCE ONLY — NOT APPLIED. The `.disabled` suffix keeps this file out of
# `kubectl apply -f manifests/` (kubectl only reads *.yaml / *.yml / *.json).
# Rename to `.yaml` ONLY on a GPU cluster — the lab cluster is CPU-only and this
# requests nvidia.com/gpu, which will leave the pod Pending forever on CPU nodes.
#
# This shows how the same TinyLlama endpoint would look in production on GPU using
# KServe's built-in vLLM-backed Hugging Face runtime instead of our custom CPU predictor.
# vLLM is GPU-only; that is exactly why the live lab uses the custom transformers predictor.
# =============================================================================
apiVersion: serving.kserve.io/v1beta1
kind: InferenceService
metadata:
  name: tinyllama-completion-gpu
  labels:
    nfcu-session-4/lab: reference
spec:
  predictor:
    minReplicas: 0
    maxReplicas: 3
    model:
      modelFormat:
        name: huggingface
      args:
        - --model_name=tinyllama
        - --model_id=TinyLlama/TinyLlama-1.1B-Chat-v1.0
        # vLLM is the default HF backend on GPU and gives much higher throughput.
        - --backend=vllm
      resources:
        requests:
          cpu: "2"
          memory: 8Gi
          nvidia.com/gpu: "1"   # <-- requires a GPU node; Pending on the CPU lab cluster
        limits:
          nvidia.com/gpu: "1"
    # On a GPU cluster you would also add a nodeSelector / tolerations for the GPU pool,
    # e.g. the NVIDIA GPU Operator's node labels. Omitted here since this never applies.
