# Build artifacts and local state — never commit these.

# Model artifacts (generated deterministically; see manifests/model-artifacts/)
*.tar.gz
model-artifacts/*.bst
model-artifacts/model-v*/

# Cluster credentials
kubeconfig
*.kubeconfig

# Environment files
.env
.env.*

# Terraform state and local config
terraform.tfstate
terraform.tfstate.*
.terraform/
*.tfvars
# NOTE: .terraform.lock.hcl is intentionally committed (reproducible provider
# versions). It carries hashes for linux/darwin on amd64/arm64 so it works on
# attendee laptops; regenerate with `terraform providers lock -platform=...`.

# ...but keep the annotated examples
!*.tfvars.example

# k6 result dumps
*.k6-summary.json

# OS / editor cruft
.DS_Store
*.swp
